{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "incremental": true,
    "isolatedModules": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": ["src/server/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/renderer",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.integration.test.ts"
  ]
}
