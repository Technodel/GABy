# ── Server ──────────────────────────────────────────────────────────────────────
SUNY_PORT=3000
NODE_ENV=production
SUNY_DB_PATH=./data/suny.db
SUNY_ADMIN_PASSWORD=change_this_now
SUNY_SECRET_JWT=change_this_to_a_long_random_secret_string_min_32_chars
SUNY_ALLOWED_ORIGIN=https://suny.technodel.tech

# ── AI / LLM API Keys ──────────────────────────────────────────────────────────

# Groq API key — used for FREE mode. Model: llama-3.3-70b-versatile
SUNY_GROQ_KEY=gsk_your_groq_key_here

# DeepSeek API key — used for FAST, SMART, and PRO modes.
# DeepSeek (deepseek-chat) is excellent at following complex system instructions
# and is the recommended model for reliable coding assistance.
SUNY_DEEPSEEK_KEY=sk-your_deepseek_key_here

# OpenRouter API key — fallback provider
# SUNY_OPENROUTER_KEY=sk-or-your_openrouter_key_here

# ── Web Search API Keys ────────────────────────────────────────────────────────
# At least one web search key needed for the web_search tool to work
# Get Serper at https://serper.dev
# Get SerpAPI at https://serpapi.com
# TAVILY_API_KEY=
# SERPAPI_KEY=
# SERPER_API_KEY=
