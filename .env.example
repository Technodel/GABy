# ═══════════════════════════════════════════════════════════════
# SUNy — Environment Configuration
# Copy this to .env and fill in your keys
# ═══════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────────
SUNY_PORT=3000
NODE_ENV=production
SUNY_DB_PATH=./data/suny.db
SUNY_ADMIN_PASSWORD=change_this_now
SUNY_SECRET_JWT=change_this_to_a_long_random_secret_string_min_32_chars
SUNY_ALLOWED_ORIGIN=https://suny.technodel.tech

# ── AI / LLM API Keys ──────────────────────────────────────────────────
# SUNy reads keys from .env and auto-seeds them into the DB on first startup.
# Order of providers per tier:
#   free:  Groq (primary) → DeepSeek (fallback) → OpenRouter → Gemini
#   fast:  DeepSeek (primary) → OpenRouter (fallback) → Gemini
#   smart: DeepSeek (primary) → OpenRouter (fallback) → Gemini
#   pro:   DeepSeek (primary) → HuggingFace (fallback) → OpenRouter → Gemini

# Groq — used for FREE tier (llama-3.3-70b-versatile)
GROQ_API_KEY=gsk_your_groq_key_here

# DeepSeek — used for FAST, SMART, and PRO tiers (deepseek-chat)
DEEPSEEK_API_KEY=sk-your_deepseek_key_here

# OpenRouter — fallback for all tiers
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# Gemini — additional fallback for all tiers
GEMINI_API_KEY=your_gemini_key_here

# ── Web Search API Keys ────────────────────────────────────────────────
# At least one needed for web_search tool to work
SERPAPI_API_KEY=your_serpapi_key_here
SERPER_API_KEY=your_serper_key_here

# ── Web Scraping (optional) ────────────────────────────────────────────
SCRAPINGBEE_API_KEY=
SCRAPE_DO_API_KEY=
OXYLABS_USERNAME=
OXYLABS_PASSWORD=
